# =========================================================================
# Environment variables for the portfolio site.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =========================================================================

# --- Database (PostgreSQL via Supabase/Neon) ---
# Pooled connection used at runtime (transaction mode, pgbouncer).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection used for migrations / `prisma db push` (session mode).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Auth (NextAuth.js) ---
# Generate with: openssl rand -base64 32   (use a fresh value in production)
NEXTAUTH_SECRET=""
# Base URL of the app. http://localhost:3000 for local dev.
NEXTAUTH_URL="http://localhost:3000"

# --- Seed admin user (prisma/seed.ts creates the single admin) ---
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# --- Image storage (Vercel Blob) ---
# Needed once POST /api/upload is implemented (build step 5).
# Vercel Dashboard → Storage → your Blob store → tokens.
BLOB_READ_WRITE_TOKEN=""
